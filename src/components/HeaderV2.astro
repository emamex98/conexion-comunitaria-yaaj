---
import { Image } from "astro:assets";
import logoWeb from "../assets/logo_web.webp";

const navItems = [
  { label: "Inicio", href: "/" },
  { label: "Conócenos", href: "/conocenos" },
  { label: "Organizaciones", href: "/organizaciones" },
  { label: "Resultados", href: "/resultados" },
  { label: "Convocatoria", href: "/convocatoria" },
  { label: "Noticias", href: "/noticias" },
  { label: "Contacto", href: "/contacto" },
];
---

<header class="site-header-v2" data-site-header-v2>
  <div class="header-pill">
    <a class="logo-link" href="/" aria-label="Conexion Comunitaria inicio">
      <Image
        src={logoWeb}
        alt="Conexion Comunitaria"
        class="site-logo"
        loading="eager"
      />
    </a>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Abrir menu"
      aria-controls="primary-navigation-v2"
      aria-expanded="false"
      data-menu-toggle
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav
      id="primary-navigation-v2"
      class="main-nav"
      aria-label="Navegacion principal"
      data-main-nav
    >
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector("[data-site-header-v2]");
  const toggle = header?.querySelector("[data-menu-toggle]");
  const nav = header?.querySelector("[data-main-nav]");

  const setMenuOpen = (isOpen) => {
    header?.toggleAttribute("data-menu-open", isOpen);
    toggle?.setAttribute("aria-expanded", String(isOpen));
    toggle?.setAttribute("aria-label", isOpen ? "Cerrar menu" : "Abrir menu");
  };

  toggle?.addEventListener("click", () => {
    setMenuOpen(!header?.hasAttribute("data-menu-open"));
  });

  nav?.addEventListener("click", (event) => {
    if (event.target instanceof HTMLAnchorElement) {
      setMenuOpen(false);
    }
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      setMenuOpen(false);
    }
  });

  window.addEventListener("resize", () => {
    if (window.matchMedia("(min-width: 901px)").matches) {
      setMenuOpen(false);
    }
  });
</script>

<style>
  .site-header-v2 {
    position: sticky;
    top: clamp(0.75rem, 2vw, 1.2rem);
    z-index: 20;
    pointer-events: none;
  }

  .header-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(0.75rem, 1.8vw, 1.6rem);
    width: min(calc(100% - (var(--gutter) * 2)), var(--page-max));
    min-height: clamp(4.25rem, 7vw, 5.75rem);
    margin: 0 auto;
    border: 1px solid rgb(30 75 106 / 0.08);
    border-radius: 999px;
    background: rgb(230 255 240 / 0.84);
    padding: 0.68rem clamp(0.82rem, 1.5vw, 1.1rem) 0.68rem
      clamp(0.95rem, 1.8vw, 1.35rem);
    box-shadow:
      0 1.2rem 3rem rgb(30 75 106 / 0.12),
      inset 0 1px 0 rgb(255 255 255 / 0.56);
    backdrop-filter: blur(2px) saturate(160%);
    -webkit-backdrop-filter: blur(2px) saturate(160%);
    pointer-events: auto;
  }

  .logo-link {
    position: relative;
    z-index: 31;
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .site-logo {
    display: block;
    width: auto;
    max-width: min(31vw, 12rem);
    height: clamp(2.7rem, 4vw, 3.95rem);
  }

  .main-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 0.58rem clamp(0.66rem, 1.5vw, 1.25rem);
    color: var(--primary-blue);
    font-size: clamp(0.72rem, 0.86vw, 0.84rem);
    font-weight: 900;
    text-transform: uppercase;
  }

  .main-nav a {
    border-radius: 999px;
    padding: 0.35rem 0;
  }

  .main-nav a:focus-visible,
  .main-nav a:hover {
    color: #0d2c43;
    text-decoration: underline;
    text-underline-offset: 0.35em;
  }

  .menu-toggle {
    position: relative;
    z-index: 31;
    display: none;
    width: 2.75rem;
    aspect-ratio: 1;
    border: 0;
    border-radius: 50%;
    background: var(--primary-blue);
    color: var(--white);
    padding: 0.72rem;
    cursor: pointer;
    touch-action: manipulation;
  }

  .menu-toggle span {
    display: block;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .menu-toggle span + span {
    margin-top: 0.28rem;
  }

  .menu-toggle:focus-visible {
    outline: 3px solid rgb(30 75 106 / 0.28);
    outline-offset: 3px;
  }

  .site-header-v2[data-menu-open] .menu-toggle span:first-child {
    transform: translateY(0.42rem) rotate(45deg);
  }

  .site-header-v2[data-menu-open] .menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .site-header-v2[data-menu-open] .menu-toggle span:last-child {
    transform: translateY(-0.42rem) rotate(-45deg);
  }

  @media (max-width: 900px) {
    .site-header-v2 {
      position: fixed;
      top: max(0.85rem, env(safe-area-inset-top));
      right: 0;
      left: 0;
    }

    .header-pill {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-rows: 3.3rem 0fr;
      align-items: center;
      align-content: start;
      column-gap: clamp(1rem, 3vw, 2.75rem);
      row-gap: 0;
      width: min(calc(100% - 1.5rem), 42rem);
      min-height: 4.65rem;
      border-radius: 2.35rem;
      overflow: hidden;
      padding: 0.65rem 0.95rem 0.65rem 1.2rem;
      transition:
        grid-template-rows 220ms ease,
        border-radius 220ms ease,
        background-color 220ms ease,
        box-shadow 220ms ease;
      transition-delay: 130ms, 130ms, 130ms, 130ms;
    }

    .site-logo {
      max-width: min(46vw, 12rem);
      height: clamp(2.55rem, 10vw, 3.6rem);
    }

    .menu-toggle {
      display: grid;
      align-self: center;
      align-content: center;
      margin-left: auto;
    }

    .logo-link {
      align-self: center;
    }

    .main-nav {
      grid-column: 1 / -1;
      align-self: start;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      align-content: start;
      justify-items: start;
      gap: 0.95rem;
      min-height: 0;
      overflow: hidden;
      color: var(--primary-blue);
      font-size: clamp(1.18rem, 5.3vw, 1.5rem);
      line-height: 1.02;
      text-align: left;
      visibility: hidden;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-0.45rem);
      transition:
        opacity 190ms ease,
        transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
        visibility 0s linear 420ms;
    }

    .main-nav a {
      display: block;
      width: 100%;
      max-width: 100%;
      padding: 0.32rem 0.15rem;
      overflow-wrap: anywhere;
      opacity: 0;
      transform: translateY(-0.6rem);
      transition:
        opacity 180ms ease,
        transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: 0ms;
    }

    .site-header-v2[data-menu-open] .main-nav {
      padding: 1.35rem 0 0.75rem;
      visibility: visible;
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
      transition-delay: 0ms;
    }

    .site-header-v2[data-menu-open] .header-pill {
      grid-template-rows: 3.3rem 1fr;
      border-radius: 2.1rem;
      background: rgb(230 255 240 / 0.84);
      backdrop-filter: blur(2px) saturate(160%);
      -webkit-backdrop-filter: blur(2px) saturate(160%);
      transition-delay: 0ms;
    }

    .site-header-v2[data-menu-open] .main-nav a {
      opacity: 1;
      transform: translateY(0);
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(1) {
      transition-delay: 70ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(2) {
      transition-delay: 105ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(3) {
      transition-delay: 140ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(4) {
      transition-delay: 175ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(5) {
      transition-delay: 210ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(6) {
      transition-delay: 245ms;
    }

    .site-header-v2[data-menu-open] .main-nav a:nth-child(7) {
      transition-delay: 280ms;
    }
  }
</style>
