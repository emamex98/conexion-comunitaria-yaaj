---
import { Image } from "astro:assets";
import LogoYaaj from "../assets/logo_yaaj_blanco.webp";
import LogoGilead from "../assets/logo_gilead_blanco.webp";
---

<footer class="site-footer">
  <div class="footer-inner">
    <section>
      <h2>YAAJ MEXICO A.C.</h2>
      <p>
        Yaaj Mexico es una organización sin fines de lucro, apartidista y laica
        encargada de defender, promover y proteger los Derechos Humanos de la
        población LGBTI+ en México.
      </p>
    </section>

    <div class="footer-logos" aria-label="Logotipos de apoyo">
      <Image
        src={LogoYaaj}
        alt="Logo Yaaj"
        class="footer-logo"
        loading="eager"
      />
      <Image
        src={LogoGilead}
        alt="Logo Gilead"
        class="footer-logo"
        loading="eager"
      />
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--primary-blue);
    color: var(--white);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 5vw, 5rem);
    margin: 0 auto;
    max-width: var(--page-max);
    padding: clamp(2.5rem, 6vw, 4rem) var(--gutter);
  }

  .footer-logo {
    display: block;
    width: auto;
    max-width: min(42vw, 15rem);
    height: clamp(3.25rem, 5.5vw, 5rem);
  }

  h2 {
    margin: 0 0 0.8rem;
    font-size: 0.9rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  p {
    margin: 0;
    max-width: 28rem;
    color: rgb(255 255 255 / 0.82);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .footer-logos {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(1rem, 3vw, 2rem);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 900;
    letter-spacing: 0;
  }

  @media (max-width: 760px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }

    .footer-logos {
      justify-content: flex-start;
    }
  }
</style>
