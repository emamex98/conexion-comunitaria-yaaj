---
import Footer from "../components/Footer.astro";
import Header from "../components/HeaderV2.astro";

const {
  title = "Conexión Comunitaria",
  description = "Pruebas de VIH al alcance de todxs.",
} = Astro.props;

const rawTitle = title.replace("Conexión Comunitaria", "").trim();
const cleanTitle = rawTitle
  ? `${title} | Conexión Comunitaria`
  : "Conexión Comunitaria";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{cleanTitle}</title>
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Conexión" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={cleanTitle} />
    <meta property="og:description" content="Juntxs en la prevención del VIH" />
    <meta property="og:image" content="/og-image.png" />
  </head>
  <body>
    <Header />

    <main class="site-main">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --primary-green: #e6fff0;
    --primary-blue: #1e4b6a;
    --accent-yellow: #ffd95c;
    --ink: #19364b;
    --muted: #476171;
    --white: #ffffff;
    --page-max: 1120px;
    --gutter: clamp(1.25rem, 4vw, 4rem);
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
    color: var(--ink);
    background: var(--primary-green);
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--white);
  }

  body.nav-open {
    overflow: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-main {
    background: var(--white);
  }
</style>
